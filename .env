# shellcheck shell=bash disable=2034

# The <title> of the app
VITE_APP_TITLE="Playground (Vue)"

# Serve R2 assets from public/r2/ instead of the proxy server.
#
# That folder is git-ignored, as in production this uses the Cloudflare Pages
# function to resolve assets like "/r2/example.webp".
#
# @default "false"
# BUILDTIME_R2_LOCAL="false"

# URL to get external Cloudflare R2 assets from.
#
# This was designed with the intent that it be used as a
# proxy for development. When undefined, Cloudflare will
# use the pages function to get data from R2.
#
# This should be a URL that accepts paths in the form
# "/r2/foobar.webp".
#
# @default: undefined
# BUILDTIME_ASSET_URL=

# Start with Tailwind CSS enabled.
# @default undefined
# VITE_TAILWIND_ENABLED=

# Path to the `sunrise-cli` project.
#
# @default "../sunrise-cli"
# BUILDTIME_SUNRISE_CLI_ROOT="../sunrise-cli"

# Path to the `date-diff` project.
#
# @default "../date-diff"
# BUILDTIME_SUNRISE_CLI_ROOT="../date-diff"

# Whether to build features that require WASM
#
# @default "true"
# BUILDTIME_WASM_SUPPORTED="true"

# Make the build reproducible
#
# This allows for comparing the contents of the dist/ directory from multiple builds by disabling hashing, amongst other things.
#
# @default "false"
# BUILDTIME_REPRODUCIBLE_ENABLED="false"

# Try to adjust settings to account for building on devices with low memory (e.g. a Raspberry Pi).
#
# @default "false"
# BUILDTIME_LOW_MEMORY="false"

# Resolve static variables (design tokens) to hard-coded values
#
# @default "false"
# BUILDTIME_RESOLVE_STATIC_VARIABLES="false"

# Enable @sentry/vite-plugin
#
# This allows Sentry to autmatically create releases and upload source maps.
#
# @default undefined
# BUILDTIME_SENTRY_ENABLED=

# Default serve host
#
# @default undefined
# BUILDTIME_HOST=

# Inject a mobile debugging console.
#
# See https://eruda.liriliri.io/ for details.
#
# @default undefined
# BUILDTIME_ERUDA_ENABLED=

# Build with Tailwind features
#
# @default "true"
# BUILDTIME_TAILWIND_SUPPORTED="true"

# vim: ft=sh
