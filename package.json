{
  "name": "playground-vue",
  "version": "0.0.0",
  "scripts": {
    "dev": "concurrently --kill-others --passthrough-arguments 'pnpm run build:tokens:watch' 'vite {@}' --",
    "build": "vite build",
    "build:all": "pnpm build:tokens && pnpm build:tailwind && vite build",
    "build:all-no-tailwind": "pnpm build:tokens && vite build",
    "build:tokens": "style-dictionary build --config ./sd.config.ts",
    "build:tokens:watch": "chokidar 'sd.config.ts' 'src/tokens/**/*.ts' --initial --command 'pnpm run build:tokens'",
    "build:tailwind": "tailwindcss --minify --input ./src/tailwind.css --output ./public/tailwind.min.css",
    "preview": "vite preview",
    "typecheck": "vue-tsc -b",
    "lint": "eslint . --cache --concurrency auto",
    "lint:style": "stylelint 'src/**/*.{vue,css}'",
    "lint:ci": "eslint --cache --cache-strategy content --concurrency auto --max-warnings 0 . && pnpm lint:style && prettier --check .",
    "format": "eslint --cache --concurrency auto --fix --fix-type layout . && pnpm lint:style --fix && prettier --write .",
    "test": "vitest",
    "test:node": "node --test --test-reporter=spec",
    "test:run": "vitest run",
    "coverage": "vitest run --typecheck --isolate true --coverage"
  },
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f",
  "type": "module",
  "dependencies": {
    "@sentry/vue": "^10.53.1",
    "@sentry/wasm": "^10.53.1",
    "rrweb": "2.0.0-alpha.4",
    "temporal-polyfill": "^0.3.2",
    "vite-plugin-wasm": "^3.6.0",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7",
    "wavesurfer.js": "7.12.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260520.1",
    "@dreamsicle.io/stylelint-config-tailwindcss": "^1.2.2",
    "@eslint/js": "^10.0.1",
    "@heroicons/vue": "^2.2.0",
    "@highlightjs/vue-plugin": "^2.1.2",
    "@observablehq/plot": "^0.6.17",
    "@sentry/vite-plugin": "^5.3.0",
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/chroma-js": "^3.1.2",
    "@types/d3": "^7.4.3",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.7",
    "@vue/test-utils": "^2.4.10",
    "@vue/typescript-plugin": "^3.3.1",
    "change-case": "^5.4.4",
    "chokidar-cli": "^3.0.0",
    "chroma-js": "^3.2.0",
    "concurrently": "^9.2.1",
    "d3": "^7.9.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-tsdoc": "^0.5.2",
    "eslint-plugin-vue": "^10.9.1",
    "fast-glob": "^3.3.3",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "highlight.js": "^11.11.1",
    "lightningcss": "^1.32.0",
    "modern-normalize": "^3.0.1",
    "pitchfinder": "^2.3.4",
    "pitchy": "^4.1.0",
    "postcss": "^8.5.15",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "style-dictionary": "^5.4.1",
    "stylelint": "^17.12.0",
    "stylelint-config-clean-order": "^8.0.2",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.13",
    "vitest": "4.1.7",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "~3.3.1"
  }
}
