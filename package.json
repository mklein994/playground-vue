{
  "name": "playground-vue",
  "version": "0.0.0",
  "scripts": {
    "dev": "concurrently --kill-others --passthrough-arguments 'pnpm run build:tokens:watch' 'vite {@}' --",
    "build": "vite build",
    "build:all": "pnpm build:tokens && pnpm build:tailwind && vite build",
    "build:all-no-tailwind": "pnpm build:tokens && vite build",
    "build:tokens": "style-dictionary build --config ./sd.config.ts",
    "build:tokens:watch": "chokidar 'sd.config.ts' 'src/tokens/**/*.ts' --initial --command 'pnpm run build:tokens'",
    "build:tailwind": "tailwindcss --minify --input ./src/tailwind.css --output ./public/tailwind.min.css",
    "preview": "vite preview",
    "typecheck": "vue-tsc --build",
    "lint": "eslint . --cache --concurrency ${ESLINT_THREADS:-auto}",
    "lint:style": "stylelint 'src/**/*.{vue,css}'",
    "lint:ci": "eslint --cache --cache-strategy content --concurrency ${ESLINT_THREADS:-auto} --max-warnings 0 . && pnpm lint:style && prettier --check .",
    "format": "eslint --cache --concurrency ${ESLINT_THREADS:-auto} --fix --fix-type layout . && pnpm lint:style --fix && prettier --write .",
    "test": "vitest",
    "test:node": "node --test --test-reporter=spec",
    "test:run": "vitest run",
    "coverage": "vitest run --typecheck --isolate true --coverage"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "type": "module",
  "dependencies": {
    "@sentry/vue": "^10.62.0",
    "@sentry/wasm": "^10.62.0",
    "rrweb": "2.0.1",
    "temporal-polyfill": "^1.0.1",
    "vite-plugin-wasm": "^3.6.0",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0",
    "wavesurfer.js": "7.12.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260627.1",
    "@dreamsicle.io/stylelint-config-tailwindcss": "^1.2.2",
    "@eslint/js": "^10.0.1",
    "@heroicons/vue": "^2.2.0",
    "@highlightjs/vue-plugin": "^2.1.2",
    "@observablehq/plot": "^0.6.17",
    "@sentry/vite-plugin": "^5.3.0",
    "@tailwindcss/cli": "^4.3.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "@types/chroma-js": "^3.1.2",
    "@types/d3": "^7.4.3",
    "@types/node": "^26.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "@vue/typescript-plugin": "^3.3.5",
    "change-case": "^5.4.4",
    "chokidar-cli": "^3.0.0",
    "chroma-js": "^3.2.0",
    "concurrently": "^10.0.3",
    "d3": "^7.9.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-tsdoc": "^0.5.2",
    "eslint-plugin-vue": "^10.9.2",
    "fast-glob": "^3.3.3",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "highlight.js": "^11.11.1",
    "lightningcss": "^1.32.0",
    "modern-normalize": "^3.0.1",
    "pitchfinder": "^2.3.4",
    "pitchy": "^4.1.0",
    "postcss": "^8.5.15",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.5",
    "sass": "^1.101.0",
    "style-dictionary": "^5.5.0",
    "stylelint": "^17.14.0",
    "stylelint-config-clean-order": "^10.0.0",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "4.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "~3.3.5"
  }
}
