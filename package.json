{
  "name": "playground-vue",
  "version": "0.0.0",
  "scripts": {
    "dev": "concurrently --kill-others --passthrough-arguments 'pnpm run build:tokens:watch' 'vite {@}' --",
    "build": "vite build",
    "build:all": "pnpm build:tokens && pnpm build:tailwind && vite build",
    "build:all-no-tailwind": "pnpm build:tokens && vite build",
    "build:tokens": "style-dictionary build --config ./sd.config.ts",
    "build:tokens:watch": "chokidar 'sd.config.ts' 'src/tokens/**/*.ts' --initial --command 'pnpm run build:tokens'",
    "build:tailwind": "tailwindcss --minify --input ./src/tailwind.css --output ./public/tailwind.min.css",
    "preview": "vite preview",
    "typecheck:config": "vue-tsc --composite false -p tsconfig.vite-config.json",
    "typecheck:workers": "vue-tsc --composite false -p tsconfig.workers.json",
    "typecheck:app": "vue-tsc --composite false -p tsconfig.app.json",
    "typecheck:tests": "vue-tsc --composite false -p tsconfig.vitest.json",
    "typecheck:node-tests": "vue-tsc --composite false -p ./tests/tsconfig.node-tests.json",
    "typecheck:sd": "vue-tsc --composite false -p ./tsconfig.sd.json",
    "typecheck": "pnpm typecheck:config && pnpm typecheck:workers && pnpm typecheck:sd && pnpm typecheck:tests && pnpm typecheck:node-tests",
    "lint": "eslint . --cache --concurrency auto",
    "lint:style": "stylelint 'src/**/*.{vue,css}'",
    "lint:ci": "eslint --cache --cache-strategy content --concurrency auto --max-warnings 0 . && pnpm lint:style && prettier --check .",
    "format": "eslint --cache --concurrency auto --fix --fix-type layout . && pnpm lint:style --fix && prettier --write .",
    "test": "vitest",
    "test:node": "node --test --test-reporter=spec",
    "test:run": "vitest run",
    "coverage": "vitest run --typecheck --isolate true --coverage"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "type": "module",
  "dependencies": {
    "@sentry/vue": "^10.49.0",
    "@sentry/wasm": "^10.49.0",
    "rrweb": "2.0.0-alpha.4",
    "temporal-polyfill": "^0.3.2",
    "vite-plugin-wasm": "^3.6.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "wavesurfer.js": "7.12.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@heroicons/vue": "^2.2.0",
    "@highlightjs/vue-plugin": "^2.1.2",
    "@observablehq/plot": "^0.6.17",
    "@sentry/vite-plugin": "^5.2.0",
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/chroma-js": "^3.1.2",
    "@types/d3": "^7.4.3",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/typescript-plugin": "^3.2.7",
    "change-case": "^5.4.4",
    "chokidar-cli": "^3.0.0",
    "chroma-js": "^3.2.0",
    "concurrently": "^9.2.1",
    "d3": "^7.9.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-tsdoc": "^0.5.2",
    "eslint-plugin-vue": "^10.8.0",
    "fast-glob": "^3.3.3",
    "globals": "^17.5.0",
    "happy-dom": "^20.9.0",
    "highlight.js": "^11.11.1",
    "lightningcss": "^1.32.0",
    "modern-normalize": "^3.0.1",
    "pitchfinder": "^2.3.4",
    "pitchy": "^4.1.0",
    "postcss": "^8.5.10",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "style-dictionary": "^5.4.0",
    "stylelint": "^17.8.0",
    "stylelint-config-clean-order": "^8.0.1",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-tailwindcss": "^1.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.9",
    "vitest": "4.1.4",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "~3.2.7"
  }
}
